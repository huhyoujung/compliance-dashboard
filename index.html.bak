<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>확증임상 순응률 대시보드</title>

  <!-- CDN -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>
  <script src="https://cdn.plot.ly/plotly-2.35.2.min.js"></script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background: #f5f7fa; color: #333; }

    /* ── 레이아웃 ── */
    .layout { display: flex; min-height: 100vh; }

    .sidebar {
      width: 240px; min-width: 200px;
      background: #fff;
      border-right: 1px solid #e0e0e0;
      padding: 24px 16px;
      display: flex; flex-direction: column; gap: 16px;
      flex-shrink: 0;
    }
    .sidebar h2 { font-size: 14px; color: #888; text-transform: uppercase; letter-spacing: .05em; }

    .main { flex: 1; padding: 28px 32px; overflow-x: hidden; }
    h1 { font-size: 22px; font-weight: 700; margin-bottom: 4px; }
    .caption { font-size: 12px; color: #888; margin-bottom: 20px; }

    /* ── 카드 ── */
    .cards { display: flex; gap: 16px; margin-bottom: 24px; flex-wrap: wrap; }
    .card {
      background: #fff; border-radius: 10px; padding: 16px 20px;
      box-shadow: 0 1px 4px rgba(0,0,0,.07);
      flex: 1; min-width: 140px;
    }
    .card-label { font-size: 13px; color: #666; margin-bottom: 6px; }
    .card-value { font-size: 28px; font-weight: 700; }
    .card-value.danger { color: #e53935; }
    .card-value.success { color: #43a047; }

    /* ── 필터 ── */
    .filter-group { display: flex; flex-direction: column; gap: 8px; }
    .filter-group label { font-size: 13px; font-weight: 600; }
    select, .multiselect-wrap { width: 100%; border: 1px solid #ddd; border-radius: 6px; padding: 6px 8px; font-size: 13px; background: #fff; }
    .multiselect-wrap { max-height: 180px; overflow-y: auto; }
    .multiselect-wrap label { display: flex; align-items: center; gap: 6px; font-weight: 400; padding: 3px 0; cursor: pointer; }
    .checkbox-row { display: flex; align-items: center; gap: 8px; font-size: 13px; cursor: pointer; }

    /* ── 버튼 ── */
    button.refresh-btn {
      width: 100%; padding: 8px; border: none; border-radius: 6px;
      background: #1a73e8; color: #fff; font-size: 13px; cursor: pointer; font-weight: 600;
    }
    button.refresh-btn:hover { background: #1558c0; }

    /* ── 탭 ── */
    .tabs { display: flex; gap: 0; border-bottom: 2px solid #e0e0e0; margin-bottom: 20px; }
    .tab-btn {
      padding: 10px 18px; border: none; background: none; font-size: 14px;
      cursor: pointer; color: #666; border-bottom: 2px solid transparent; margin-bottom: -2px;
    }
    .tab-btn.active { color: #1a73e8; border-bottom-color: #1a73e8; font-weight: 600; }

    /* ── 테이블 ── */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; font-size: 13px; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,.07); }
    th { background: #f8f9fa; padding: 10px 12px; text-align: left; font-weight: 600; color: #444; border-bottom: 2px solid #e0e0e0; white-space: nowrap; cursor: pointer; user-select: none; }
    th:hover { background: #eef2ff; }
    td { padding: 9px 12px; border-bottom: 1px solid #f0f0f0; white-space: nowrap; }
    tr:last-child td { border-bottom: none; }
    .badge-ended { font-size: 10px; background: #e0e0e0; padding: 2px 6px; border-radius: 10px; color: #555; margin-left: 4px; }

    /* ── 범례 ── */
    .legend { display: flex; gap: 16px; margin-bottom: 10px; font-size: 13px; }
    .legend-item { display: flex; align-items: center; gap: 6px; }
    .legend-dot { width: 12px; height: 12px; border-radius: 2px; }

    /* ── 스피너 ── */
    #spinner { display: none; position: fixed; inset: 0; background: rgba(255,255,255,.7); justify-content: center; align-items: center; z-index: 999; font-size: 16px; font-weight: 600; color: #1a73e8; }
    #spinner.show { display: flex; }

    /* ── 반응형 ── */
    @media (max-width: 700px) {
      .layout { flex-direction: column; }
      .sidebar { width: 100%; border-right: none; border-bottom: 1px solid #e0e0e0; }
    }
  </style>
</head>
<body>

<div id="spinner">⏳ 데이터를 불러오는 중...</div>

<div class="layout">
  <!-- 사이드바 -->
  <aside class="sidebar">
    <h2>💊 순응률 대시보드</h2>

    <button class="refresh-btn" onclick="loadData(true)">🔄 데이터 새로고침</button>

    <hr style="border:none;border-top:1px solid #eee">
    <h2>필터</h2>

    <div class="filter-group">
      <label>기관 선택</label>
      <div class="multiselect-wrap" id="hospital-filter"></div>
    </div>

    <label class="checkbox-row">
      <input type="checkbox" id="no-use-only" onchange="applyFilters()">
      미사용자만 보기
    </label>

    <label class="checkbox-row">
      <input type="checkbox" id="yellow-card-only" onchange="applyFilters()">
      옐로카드 있는 환자만 보기
    </label>
  </aside>

  <!-- 메인 -->
  <main class="main">
    <h1>확증임상 순응률 대시보드</h1>
    <div class="caption" id="caption">-</div>

    <!-- 요약 카드 -->
    <div class="cards">
      <div class="card">
        <div class="card-label">전체 대상자</div>
        <div class="card-value" id="card-total">-</div>
      </div>
      <div class="card">
        <div class="card-label">미사용자</div>
        <div class="card-value danger" id="card-nouse">-</div>
      </div>
      <div class="card">
        <div class="card-label">옐로카드 보유자</div>
        <div class="card-value danger" id="card-yellow">-</div>
      </div>
      <div class="card">
        <div class="card-label">평균 순응률</div>
        <div class="card-value success" id="card-avg">-</div>
      </div>
    </div>

    <!-- 탭 -->
    <div class="tabs">
      <button class="tab-btn active" onclick="switchTab('table', this)">📋 환자 테이블</button>
      <button class="tab-btn" onclick="switchTab('heatmap', this)">🗓 일별 히트맵</button>
      <button class="tab-btn" onclick="switchTab('dist', this)">📊 순응률 분포</button>
      <button class="tab-btn" onclick="switchTab('hospital', this)">🏥 기관별 요약</button>
    </div>

    <div id="tab-table">
      <div class="table-wrap">
        <table id="patient-table">
          <thead>
            <tr>
              <th onclick="sortTable('subject_id')">피험자번호 ↕</th>
              <th onclick="sortTable('hospital')">소속기관 ↕</th>
              <th onclick="sortTable('start_dt')">처방 시작일 ↕</th>
              <th onclick="sortTable('end_dt')">처방 종료일 ↕</th>
              <th onclick="sortTable('elapsed_days')">경과일 ↕</th>
              <th onclick="sortTable('used_days')">사용일 ↕</th>
              <th onclick="sortTable('compliance')">순응률(%) ↕</th>
              <th onclick="sortTable('yellow_cards')">옐로카드 ↕</th>
            </tr>
          </thead>
          <tbody id="table-body"></tbody>
        </table>
      </div>
      <div class="caption" id="table-caption" style="margin-top:8px"></div>
    </div>

    <div id="tab-heatmap" style="display:none">
      <div class="legend">
        <div class="legend-item"><div class="legend-dot" style="background:#28A745"></div>사용</div>
        <div class="legend-item"><div class="legend-dot" style="background:#FF6B6B"></div>미사용</div>
        <div class="legend-item"><div class="legend-dot" style="background:#E8E8E8"></div>미경과</div>
      </div>
      <div id="heatmap-chart"></div>
    </div>

    <div id="tab-dist" style="display:none">
      <div class="tabs" style="margin-bottom:12px">
        <button class="tab-btn active" onclick="switchDistTab('hist', this)">히스토그램</button>
        <button class="tab-btn" onclick="switchDistTab('box', this)">박스플롯</button>
      </div>
      <div id="dist-hist-chart"></div>
      <div id="dist-box-chart" style="display:none"></div>
    </div>

    <div id="tab-hospital" style="display:none">
      <div id="hospital-chart"></div>
    </div>
  </main>
</div>

<script>
// ── 상수 ──────────────────────────────────────────────────────────────────
const SHEET_ID = "1Ao0BR5ex4orskBqoJYskLTgl6FGzLxNCQr8nJ-nK1Mw";
const SHEET_URL = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/export?format=csv`;

const HOSPITAL_PREFIX = {
  "서울대학교병원": "h01",
  "강북삼성병원": "h02",
  "강동경희대학교병원": "h03",
  "경희대학교병원": "h04",
  "차의과대학교 분당차병원": "h05",
  "가톨릭관동대학교 국제성모병원": "h06",
};

const MAX_DAYS = 28;
const YELLOW_CARD_RULES = [
  { day: 7,  target: 3 },
  { day: 14, target: 6 },
  { day: 21, target: 9 },
  { day: 24, target: 10 },
];
let allRows = [];         // 처리된 전체 데이터
let filteredRows = [];    // 필터 적용 후
let sortKey = "yellow_cards";
let sortAsc = false;
let lastLoaded = null;

// 5분 캐시
let cachedCsv = null;
let cachedAt  = null;
const CACHE_TTL_MS = 5 * 60 * 1000;

// ── 타임존: 익일 정오(12:00) 경계 ────────────────────────────────────────
/**
 * @param {Date} startDt
 * @param {Date} referenceDt
 * @returns {number} 0~28
 */
function calcElapsedDays(startDt, referenceDt) {
  if (!startDt || isNaN(startDt) || referenceDt < startDt) return 0;
  const anchor = new Date(startDt);
  anchor.setHours(12, 0, 0, 0);
  const deltaMs = referenceDt - anchor;
  if (deltaMs < 0) return 0;
  return Math.min(Math.floor(deltaMs / 86400000) + 1, MAX_DAYS);
}

function calcCompliance(usedDays, elapsedDays) {
  if (elapsedDays === 0) return null;
  return Math.min((usedDays / elapsedDays) * 100, 100);
}

// ── CSV 파싱 & 가공 ──────────────────────────────────────────────────────
function parseCsv(csvText) {
  const result = Papa.parse(csvText, { header: false, skipEmptyLines: true });
  const rows = result.data;

  // Row 0: 메타헤더(스킵), Row 1: 컬럼명, Row 2+: 데이터
  if (rows.length < 3) return [];
  const headers = rows[1].map(h => h.trim());
  const dataRows = rows.slice(2);

  const idx = key => headers.indexOf(key);
  const now = new Date();

  return dataRows
    .filter(r => (r[idx("프로젝트명")] || "").trim() === "확증임상 프로젝트")
    .map(r => {
      const hospital    = (r[idx("소속기관")]    || "").trim();
      const accessCode  = (r[idx("액세스코드")]  || "").trim();
      const prefix      = HOSPITAL_PREFIX[hospital] || "";
      const subject_id  = prefix ? `${prefix}-${accessCode}` : accessCode;

      const startRaw = (r[idx("시작일자")] || "").trim();
      const endRaw   = (r[idx("종료일자")] || "").trim();
      const start_dt = startRaw ? new Date(startRaw) : null;
      const end_dt   = endRaw   ? new Date(endRaw)   : null;

      const usedDaysRaw = parseFloat(r[idx("사용일차")] || "0");
      const used_days   = isNaN(usedDaysRaw) ? 0 : Math.round(usedDaysRaw);

      const ref = (end_dt && end_dt < now) ? end_dt : now;
      const elapsed_days = start_dt ? calcElapsedDays(start_dt, ref) : 0;
      const compVal = calcCompliance(used_days, elapsed_days);

      const is_ended = end_dt && end_dt < now;

      // 옐로카드: 체크포인트별 목표 미달 누적
      const yellow_cards = YELLOW_CARD_RULES.reduce((cnt, rule) => {
        if (elapsed_days < rule.day) return cnt;  // 아직 미도달
        return used_days < rule.target ? cnt + 1 : cnt;
      }, 0);

      return {
        subject_id,
        hospital,
        start_dt,
        end_dt,
        start_str: startRaw,
        end_str:   endRaw,
        used_days,
        elapsed_days,
        compliance: compVal,   // null or 0~100
        yellow_cards,
        is_ended: !!is_ended,
      };
    });
}

// ── 데이터 로드 ──────────────────────────────────────────────────────────
async function loadData(forceRefresh = false) {
  const spinner = document.getElementById("spinner");
  spinner.classList.add("show");

  try {
    const now = Date.now();
    if (!forceRefresh && cachedCsv && cachedAt && (now - cachedAt) < CACHE_TTL_MS) {
      allRows = parseCsv(cachedCsv);
    } else {
      // cache-busting query param
      const url = SHEET_URL + "&t=" + now;
      const resp = await fetch(url);
      if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
      cachedCsv = await resp.text();
      cachedAt = now;
      allRows = parseCsv(cachedCsv);
    }
    lastLoaded = new Date();
    document.getElementById("caption").textContent =
      `데이터 기준: ${lastLoaded.toLocaleString("ko-KR")}  |  5분 캐시`;

    buildHospitalFilter();
    applyFilters();
  } catch (err) {
    alert("데이터 로드 실패: " + err.message);
  } finally {
    spinner.classList.remove("show");
  }
}

// ── 기관 필터 빌드 ───────────────────────────────────────────────────────
function buildHospitalFilter() {
  const hospitals = [...new Set(allRows.map(r => r.hospital).filter(Boolean))].sort();
  const wrap = document.getElementById("hospital-filter");
  wrap.innerHTML = hospitals.map(h =>
    `<label>
      <input type="checkbox" class="hospital-cb" value="${h}" checked onchange="applyFilters()">
      ${h}
    </label>`
  ).join("");
}

function getSelectedHospitals() {
  return [...document.querySelectorAll(".hospital-cb:checked")].map(cb => cb.value);
}

// ── 필터 적용 ────────────────────────────────────────────────────────────
function applyFilters() {
  const selectedHospitals = getSelectedHospitals();
  const noUseOnly = document.getElementById("no-use-only").checked;
  const yellowOnly = document.getElementById("yellow-card-only").checked;

  filteredRows = allRows.filter(r => {
    if (selectedHospitals.length && !selectedHospitals.includes(r.hospital)) return false;
    if (noUseOnly && r.used_days > 0) return false;
    if (yellowOnly && r.yellow_cards === 0) return false;
    return true;
  });

  renderCards();
  renderTable();
  renderHeatmap();
  renderDist();
  renderHospitalChart();
}

// ── 요약 카드 ────────────────────────────────────────────────────────────
function renderCards() {
  const total = filteredRows.length;
  const noUse = filteredRows.filter(r => r.used_days === 0).length;
  const yellowCount = filteredRows.filter(r => r.yellow_cards > 0 && !r.is_ended).length;
  const validRows = filteredRows.filter(r => r.elapsed_days > 0 && r.compliance !== null);
  const avg = validRows.length
    ? validRows.reduce((s, r) => s + r.compliance, 0) / validRows.length
    : null;

  document.getElementById("card-total").textContent = total + "명";
  document.getElementById("card-nouse").textContent = noUse + "명";
  document.getElementById("card-yellow").textContent = yellowCount + "명";
  document.getElementById("card-avg").textContent = avg !== null ? avg.toFixed(1) + "%" : "-";
}

// ── 테이블 ───────────────────────────────────────────────────────────────
function rowBgColor(compliance) {
  if (compliance === null) return "";
  if (compliance === 0)  return "background:#FFCCCC";
  if (compliance < 50)   return "background:#FFF3CD";
  if (compliance >= 80)  return "background:#D4EDDA";
  return "";
}

function sortTable(key) {
  if (sortKey === key) sortAsc = !sortAsc;
  else { sortKey = key; sortAsc = true; }
  renderTable();
}

function renderTable() {
  const rows = [...filteredRows];

  rows.sort((a, b) => {
    let va = a[sortKey], vb = b[sortKey];
    // null을 맨 앞으로
    if (va === null && vb === null) return 0;
    if (va === null) return sortAsc ? -1 : 1;
    if (vb === null) return sortAsc ? 1 : -1;
    if (va < vb) return sortAsc ? -1 : 1;
    if (va > vb) return sortAsc ? 1 : -1;
    return 0;
  });

  const tbody = document.getElementById("table-body");
  tbody.innerHTML = rows.map(r => {
    const comp = r.compliance !== null ? r.compliance.toFixed(1) + "%" : "N/A";
    const endedBadge = r.is_ended ? '<span class="badge-ended">종료</span>' : "";
    const bg = rowBgColor(r.compliance);
    const ycDisplay = r.yellow_cards > 0
      ? `<span style="color:#e53935;font-weight:700">${r.yellow_cards}</span>`
      : `<span style="color:#aaa">0</span>`;
    return `<tr style="${bg}">
      <td>${r.subject_id}</td>
      <td>${r.hospital}</td>
      <td>${r.start_str}${endedBadge}</td>
      <td>${r.end_str}</td>
      <td>${r.elapsed_days}</td>
      <td>${r.used_days}</td>
      <td>${comp}</td>
      <td style="text-align:center">${ycDisplay}</td>
    </tr>`;
  }).join("");

  document.getElementById("table-caption").textContent = `총 ${rows.length}명 표시 중`;
}

// ── 히트맵 ───────────────────────────────────────────────────────────────
function renderHeatmap() {
  const rows = [...filteredRows].sort((a, b) => a.subject_id.localeCompare(b.subject_id));
  if (!rows.length) {
    Plotly.purge("heatmap-chart");
    return;
  }

  const matrix = [];
  const hoverTexts = [];
  const yLabels = rows.map(r => r.subject_id);

  rows.forEach(r => {
    const rowVals  = [];
    const rowHover = [];
    for (let d = 1; d <= MAX_DAYS; d++) {
      const dayOffset = (d - 1) * 86400000;
      const dayDt = r.start_dt ? new Date(r.start_dt.getTime() + dayOffset) : null;
      const dateStr = dayDt ? dayDt.toLocaleDateString("ko-KR") : "?";

      if (d > r.elapsed_days) {
        rowVals.push(2);
        rowHover.push(`${r.subject_id} | ${d}일차 (${dateStr}) | 미경과`);
      } else if (d <= r.used_days) {
        rowVals.push(1);
        rowHover.push(`${r.subject_id} | ${d}일차 (${dateStr}) | 사용`);
      } else {
        rowVals.push(0);
        rowHover.push(`${r.subject_id} | ${d}일차 (${dateStr}) | 미사용`);
      }
    }
    matrix.push(rowVals);
    hoverTexts.push(rowHover);
  });

  const xLabels = Array.from({length: MAX_DAYS}, (_, i) => `${i+1}일`);

  const colorscale = [
    [0.00, "#FF6B6B"], [0.33, "#FF6B6B"],
    [0.34, "#28A745"], [0.66, "#28A745"],
    [0.67, "#E8E8E8"], [1.00, "#E8E8E8"],
  ];

  // 중앙값 elapsed_days 세로선
  const elapsedVals = rows.map(r => r.elapsed_days).filter(v => v > 0);
  const medianElapsed = elapsedVals.length
    ? elapsedVals.sort((a,b)=>a-b)[Math.floor(elapsedVals.length/2)]
    : null;

  const shapes = [];
  if (medianElapsed && medianElapsed <= MAX_DAYS) {
    shapes.push({
      type: "line",
      x0: medianElapsed - 0.5, x1: medianElapsed - 0.5,
      y0: -0.5, y1: rows.length - 0.5,
      xref: "x", yref: "y",
      line: { color: "#1A73E8", width: 2, dash: "dash" },
    });
  }

  const today = new Date().toLocaleDateString("ko-KR");
  const annotations = medianElapsed ? [{
    x: medianElapsed - 0.5,
    y: -0.7,
    xref: "x", yref: "y",
    text: `오늘 (${today})`,
    showarrow: false,
    font: { color: "#1A73E8", size: 11 },
    yanchor: "bottom",
  }] : [];

  const height = Math.max(300, rows.length * 36 + 100);

  Plotly.newPlot("heatmap-chart", [{
    type: "heatmap",
    z: matrix,
    x: xLabels,
    y: yLabels,
    colorscale,
    zmin: 0, zmax: 2,
    showscale: false,
    text: hoverTexts,
    hovertemplate: "%{text}<extra></extra>",
    xgap: 2, ygap: 2,
  }], {
    margin: {l: 100, r: 20, t: 40, b: 60},
    height,
    xaxis: { side: "top", title: "처방 일차" },
    yaxis: { autorange: "reversed" },
    plot_bgcolor: "white",
    paper_bgcolor: "white",
    shapes,
    annotations,
  }, { responsive: true });
}

// ── 분포 차트 ────────────────────────────────────────────────────────────
function renderDist() {
  const validRows = filteredRows.filter(r => r.compliance !== null);
  const compValues = validRows.map(r => r.compliance);

  if (!compValues.length) return;

  // 히스토그램
  Plotly.newPlot("dist-hist-chart", [{
    type: "histogram",
    x: compValues,
    marker: { color: "#4A90D9", opacity: 0.8 },
    xbins: { start: 0, end: 100, size: 10 },
  }], {
    xaxis: { title: "순응률(%)", range: [0, 100] },
    yaxis: { title: "환자 수" },
    margin: { l: 50, r: 20, t: 30, b: 50 },
    paper_bgcolor: "white",
    plot_bgcolor: "white",
  }, { responsive: true });

  // 박스플롯
  Plotly.newPlot("dist-box-chart", [{
    type: "box",
    y: compValues,
    marker: { color: "#4A90D9" },
    boxpoints: "all",
    jitter: 0.3,
    pointpos: -1.5,
    name: "순응률",
  }], {
    yaxis: { title: "순응률(%)" },
    margin: { l: 50, r: 20, t: 30, b: 30 },
    paper_bgcolor: "white",
    plot_bgcolor: "white",
  }, { responsive: true });
}

function switchDistTab(tab, btn) {
  document.getElementById("dist-hist-chart").style.display = tab === "hist" ? "" : "none";
  document.getElementById("dist-box-chart").style.display  = tab === "box"  ? "" : "none";
  document.querySelectorAll("#tab-dist .tab-btn").forEach(b => b.classList.remove("active"));
  btn.classList.add("active");
}

// ── 기관별 차트 ──────────────────────────────────────────────────────────
function renderHospitalChart() {
  const validRows = filteredRows.filter(r => r.compliance !== null);
  if (!validRows.length) return;

  const hospitalMap = {};
  validRows.forEach(r => {
    if (!hospitalMap[r.hospital]) hospitalMap[r.hospital] = [];
    hospitalMap[r.hospital].push(r.compliance);
  });

  const entries = Object.entries(hospitalMap)
    .map(([h, vals]) => ({
      hospital: h,
      avg: vals.reduce((a,b)=>a+b,0)/vals.length,
      count: vals.length,
    }))
    .sort((a,b) => a.avg - b.avg);

  const yLabels  = entries.map(e => `${e.hospital} (${e.count}명)`);
  const xValues  = entries.map(e => parseFloat(e.avg.toFixed(1)));
  const colors   = entries.map(e => e.avg >= 80 ? "#28A745" : "#4A90D9");
  const textVals = xValues.map(v => v + "%");

  Plotly.newPlot("hospital-chart", [{
    type: "bar",
    orientation: "h",
    x: xValues,
    y: yLabels,
    marker: { color: colors },
    text: textVals,
    textposition: "outside",
  }], {
    xaxis: { title: "평균 순응률(%)", range: [0, 115] },
    margin: { l: 200, r: 60, t: 30, b: 50 },
    height: Math.max(300, entries.length * 44),
    paper_bgcolor: "white",
    plot_bgcolor: "white",
  }, { responsive: true });
}

// ── 탭 전환 ──────────────────────────────────────────────────────────────
const TAB_IDS = ["table", "heatmap", "dist", "hospital"];

function switchTab(name, btn) {
  TAB_IDS.forEach(id => {
    document.getElementById(`tab-${id}`).style.display = id === name ? "" : "none";
  });
  document.querySelectorAll(".tabs:first-of-type .tab-btn").forEach(b => b.classList.remove("active"));
  btn.classList.add("active");

  // 탭 전환 시 차트 재렌더 (Plotly responsive 갱신)
  if (name === "heatmap") renderHeatmap();
  if (name === "dist")    renderDist();
  if (name === "hospital") renderHospitalChart();
}

// ── 초기 로드 ────────────────────────────────────────────────────────────
loadData();
</script>
</body>
</html>
